{
  "name": "manong-novel",
  "version": "0.1.3",
  "description": "Manong Novel — open-source AI novel writing desktop app for authors (Electron + Vue 3)",
  "main": "./out/main/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "electron-vite preview",
    "build:unpack": "pnpm run build && electron-builder --dir --config electron-builder.config.cjs --publish never",
    "build:win": "pnpm run build && electron-builder --win --config electron-builder.config.cjs --publish never",
    "build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.cjs --publish never",
    "publish:github": "powershell -ExecutionPolicy Bypass -File scripts/publish-github.ps1",
    "push": "powershell -ExecutionPolicy Bypass -File scripts/push.ps1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@headlessui/vue": "^1.7.23",
    "chart.js": "^4.5.1",
    "marked": "^16.3.0",
    "pinia": "^3.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.18",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.21",
    "echarts": "^5.6.0",
    "electron": "^39.2.6",
    "electron-builder": "^24.9.1",
    "electron-store": "8.2.0",
    "electron-vite": "^2.0.0",
    "extract-zip": "^2.0.1",
    "lucide-vue-next": "^1.0.0",
    "naive-ui": "^2.41.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "rcedit": "^5.0.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.6.3",
    "vite": "^5.0.12",
    "vitest": "2.1.9",
    "vue": "^3.4.15",
    "vue-echarts": "^7.0.3",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
